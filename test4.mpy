from machine import Pin
from utime import sleep_ms, sleep
from time import ticks_us, ticks_diff
from sys import exit

outPin = [15,2,4,16,17,5,18,19,23]
inPin  = [13,12,14,27,26,25,33,32,34]

opins = [Pin(i, Pin.OUT) for i in outPin]
ipins = [Pin(i, Pin.IN, Pin.PULL_DOWN) for i in inPin]

expected = {
15:33,
2:27,
4:14,
16:32,
17:26,
5:12,
18:34,
19:25,
23:13
}

# all outputs LOW
for p in opins:
    p.value(0)


def pin_check():

    for i in range(len(opins)):

        # turn everything OFF
        for p in opins:
            p.value(0)

        # activate one output
        opins[i].value(1)
        sleep_ms(20)

        detected = []

        for j in range(len(ipins)):
            if ipins[j].value():
                detected.append(inPin[j])

        if detected == [expected[outPin[i]]]:
            print(outPin[i], "PASS")

        else:
            print(outPin[i], "FAIL ->", detected)
            exit()

def pulse_test(out_gpio, in_gpio, tolerance_us=50, timeout_us=1000):

    out_gpio.value(0)
    sleep_ms(2)

    t_send = ticks_us()
    out_gpio.value(1)

    while in_gpio.value() == 0:
        if ticks_diff(ticks_us(), t_send) > timeout_us:
            print("TIMING FAIL -> timeout")
            out_gpio.value(0)
            return False

    t_recv = ticks_us()

    delay = ticks_diff(t_recv, t_send)

    print("Delay:", delay, "us")

    if delay <= tolerance_us:
        print("TIMING PASS")
        result = True
    else:
        print("TIMING FAIL")
        result = False

    out_gpio.value(0)
    return result


def timing_check():

    for i in range(len(opins)):

        out_gpio = opins[i]
        expected_in = expected[outPin[i]]

        in_index = inPin.index(expected_in)
        in_gpio = ipins[in_index]

        print("Testing:", outPin[i], "->", expected_in)

        if not pulse_test(out_gpio, in_gpio):
            print("HARNESS TIMING FAIL")
            exit()

# while True:

pin_check()
timing_check()

print("\nHARNESS FULL PASS\n")
